<style>
.footer { background: var(--black); color: var(--cream); }
.footer__top { padding: 4rem 0; }
.footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
}
@media(max-width:900px){ .footer__grid { grid-template-columns: 1fr 1fr; gap: 2rem; } }
@media(max-width:580px){ .footer__grid { grid-template-columns: 1fr; } }

.footer__logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  margin-bottom: 1rem;
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.3;
}
.footer__logo em { color: var(--gold-light); font-style: italic; }
.footer__logo-icon { color: var(--gold); font-size: 1.6rem; }
.footer__brand-desc { font-size: 0.875rem; color: rgba(250,246,239,0.7); line-height: 1.65; margin-bottom: 1.25rem; }
.footer__contact { display: flex; flex-direction: column; gap: 0.5rem; }
.footer__contact a, .footer__contact p {
  font-size: 0.85rem;
  color: rgba(250,246,239,0.8);
  text-decoration: none;
  margin: 0;
  transition: color var(--transition);
}
.footer__contact a:hover { color: var(--gold-light); }

.footer__col h4 {
  color: var(--gold-light);
  font-family: var(--font-serif);
  font-size: 0.95rem;
  font-weight: 700;
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.footer__col ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
.footer__col a {
  font-size: 0.875rem;
  color: rgba(250,246,239,0.75);
  text-decoration: none;
  transition: color var(--transition);
}
.footer__col a:hover { color: var(--gold-light); }

.footer__bottom {
  border-top: 1px solid rgba(250,246,239,0.1);
  padding: 1.5rem 0;
}
.footer__bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer__bottom p { font-size: 0.82rem; color: rgba(250,246,239,0.55); margin: 0; }
.footer__legal { display: flex; gap: 1.5rem; }
.footer__legal a { font-size: 0.82rem; color: rgba(250,246,239,0.55); text-decoration: none; }
.footer__legal a:hover { color: var(--gold-light); }
</style>
